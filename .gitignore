# Rust
/target
**/target/
**/*.rs.bk
Cargo.lock.bak

# Tauri
app/src-tauri/target/
app/dist/
app/build/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log

# Local env
.env
.env.*
!.env.example

# OS / build artifacts
*.exe
*.msi
*.dmg
*.AppImage

# Tauri-generated capability/ACL schemas — regenerated by `cargo tauri build`
app/src-tauri/gen/

# Bundled external tools (FFmpeg, pandoc, 7za) and their license texts.
# Binaries are too large for git and the LICENSE files travel with them
# upstream. The README under LICENSES/ is intentionally tracked.
app/src-tauri/external/*
!app/src-tauri/external/settings.ico
!app/src-tauri/external/LICENSES/
app/src-tauri/external/LICENSES/*
!app/src-tauri/external/LICENSES/README.md

# Design
assets/source/
*.psd
*.ai